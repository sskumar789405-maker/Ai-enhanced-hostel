{
  "version": 2,
  "builds": [
    {
      "src": "hostel_pg_system/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.11" }
    },
    {
      "src": "management/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/management/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "hostel_pg_system/wsgi.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  }
}
